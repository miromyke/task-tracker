# Copy to .env and adjust. Used by docker-compose.

# Bootstrap admin account. This is the only user defined outside the app; every
# other member is created in-app by an admin. APP_ADMIN_PASSWORD is required and
# is (re)applied on every boot, so it's also how you recover from a lockout.
APP_ADMIN_USER=mykhailo
APP_ADMIN_NAME=Mykhailo
APP_ADMIN_PASSWORD=change-me-now

# Secret for signing session cookies. Generate one, e.g.: openssl rand -hex 32
APP_SECRET=please-change-this-secret

# Timezone for grouping activity into calendar days (IANA name).
APP_TZ=Europe/Kyiv

# Domain the app is served on. Its DNS A record must point at this VM's
# public IP before you deploy, or Let's Encrypt can't issue a certificate.
DOMAIN=example.com

# Email Let's Encrypt uses to send certificate-expiry notices.
ACME_EMAIL=you@example.com

# --- Production sandbox (sandbox.${DOMAIN}) ---
# A separate instance with its own DB, for testing against prod safely.
# Requires a sandbox.${DOMAIN} DNS A record pointing at this VM.
# Give it its own cookie secret; admin password defaults to the prod one.
SANDBOX_ADMIN_PASSWORD=change-me-too
SANDBOX_SECRET=please-change-this-sandbox-secret
